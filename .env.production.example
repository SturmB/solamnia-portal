# Copy to `.env` in the Dockge stack directory and fill every blank.
# Docker reads this file for both container env (app/scheduler) and ${...}
# interpolation (mysql credentials, host port).

APP_NAME="Solamnia Portal"
APP_ENV=production
APP_KEY=                              # generate (no host PHP needed): echo "base64:$(openssl rand -base64 32)"
APP_DEBUG=false
APP_URL=https://solamnia.tv          # signed URLs derive from this — must be exact

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ── Database (the `mysql` service in this stack) ─────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=solamnia
DB_USERNAME=solamnia
DB_PASSWORD=                          # strong password
DB_ROOT_PASSWORD=                     # different strong password

# ── Everything on the database driver — no Redis (ADR-0002) ──────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true           # cookies are https-only (behind the tunnel)
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

# ── Mail: Resend (verify the solamnia.tv domain — SPF/DKIM — in Resend) ──────
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="news@solamnia.tv" # real solamnia.tv sender, not the example
MAIL_FROM_NAME="${APP_NAME}"

# ── Pushover: BOTH required, or the send notification silently no-ops ─────────
PUSHOVER_TOKEN=
PUSHOVER_USER=

# ── Host port the Cloudflare Tunnel points at (container listens on 8080) ────
APP_PORT=8080
