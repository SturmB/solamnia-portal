#!/usr/bin/env sh
#
# Mirror the CI gate before code leaves the machine: style check + static
# analysis + the full test suite. `composer test` is the single source of
# truth CI also runs, so a green push means a green PR. Running lint:check
# here (not just at commit) catches style debt that skipped the pre-commit
# formatter, e.g. --no-verify commits or pre-existing files.

set -e

composer test

exit 0
